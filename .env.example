# NI-Brain + optional overrides (env wins over NI-Brain fetch)
SUPABASE_SERVICE_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GEMINI_API_KEY_BACKUP=
SERPAPI_API_KEY=
RESEND_API_KEY=
RESEND_FROM_EMAIL=Jonny <northside@northsideintelligence.com>
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# GitHub PAT — workflow dispatch (outreach, research, manager dispatch)
# Accepts: AXON_GITHUB_PAT, GITHUB_PAT, or GH_PAT (env wins over ni_platform_secrets)
AXON_GITHUB_PAT=
GITHUB_PAT=
GH_PAT=

# Optional — secure Telegram webhook (set same value in BotFather / setWebhook)
TELEGRAM_WEBHOOK_SECRET=

# Required for the Match Fit posting-confirmation webhook (POST /api/axon/match-fit/posting-confirmation)
# Same value must be set as the X-Match-Fit-Webhook-Secret header on the Match Fit sender side.
MATCH_FIT_WEBHOOK_SECRET=

# Optional — protect AXON dashboard API (Bearer token or ?token= query param)
AXON_DASHBOARD_TOKEN=

# Set to 1 for dry run (no DB writes, no Telegram/Resend sends)
AXON_DRY_RUN=0

# Web UI — set to /axon when deployed at northsideintelligence.com/axon
NEXT_PUBLIC_BASE_PATH=/axon

# Web UI (Phase 3) — operator dashboard login
AXON_DASHBOARD_SECRET=

# Match Fit admin portal — access code (env wins over ni_platform_secrets; never commit value)
MF_ADMIN_ACCESS_CODE=
MF_ADMIN_SECRET=

# Match Fit Ad Tracker (AX-AD) — Meta + TikTok Ads API (env wins over ni_platform_secrets)
META_ADS_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
TIKTOK_ADS_ACCESS_TOKEN=
TIKTOK_ADS_ADVERTISER_ID=
# Optional — on-site UTM attribution mirror from Match Fit Supabase
MATCHFIT_SUPABASE_URL=
MATCHFIT_SUPABASE_SERVICE_KEY=

# Delay between Gemini prospect scans (ms) — reduces 429 rate limits
AXON_GEMINI_DELAY_MS=2500

# AX-MODEL-DAILY — local Ollama scoring (Mac cron). Heuristic used when offline.
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2
# AXON_LOCAL_MODEL_HEURISTIC=1
